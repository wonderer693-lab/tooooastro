{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "maxLength": 165
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "priceRange": {
      "type": "string"
    },
    "bestFor": {
      "type": "string"
    },
    "pros": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "integrations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "keyFeatures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "image": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate",
    "rating",
    "priceRange",
    "bestFor",
    "pros",
    "cons",
    "integrations",
    "keyFeatures"
  ]
}