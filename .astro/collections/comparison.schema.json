{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "maxLength": 165
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "winner": {
      "type": "string"
    },
    "winnerReason": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate",
    "tools",
    "winner",
    "winnerReason",
    "category"
  ]
}