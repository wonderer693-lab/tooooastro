---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Free Property Management Resources & Tools | PropertyManagePro" description="Free HOA resources, reserve study calculator, software migration checklists, and state compliance guides for property managers and association boards." canonical="https://www.propertymanagepro.com/resources/" lastUpdated="June 14, 2026">
  <h1>Free Property Management Resources</h1>
  <p>Tools, checklists, and guides to help you manage your properties more effectively.</p>

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; margin-top: 2rem;">
    <a href="/resources/reserve-study-calculator/" style="background: white; padding: 1.5rem; border-radius: 12px; border: 1px solid #e5e7eb; text-decoration: none; display: block;">
      <div style="font-size: 2rem; margin-bottom: 0.75rem;">🧮</div>
      <h2 style="font-size: 1.2rem; color: #1a1a2e; margin-bottom: 0.5rem;">HOA Reserve Study Calculator</h2>
      <p style="font-size: 0.9rem; color: #6b7280;">Estimate your association's reserve funding needs based on unit count, property type, and state requirements.</p>
    </a>

    <a href="/resources/migration-checklist/" style="background: white; padding: 1.5rem; border-radius: 12px; border: 1px solid #e5e7eb; text-decoration: none; display: block;">
      <div style="font-size: 2rem; margin-bottom: 0.75rem;">📋</div>
      <h2 style="font-size: 1.2rem; color: #1a1a2e; margin-bottom: 0.5rem;">Software Migration Checklist</h2>
      <p style="font-size: 0.9rem; color: #6b7280;">Step-by-step checklist for switching property management platforms without losing data or disrupting operations.</p>
    </a>

    <a href="/state/" style="background: white; padding: 1.5rem; border-radius: 12px; border: 1px solid #e5e7eb; text-decoration: none; display: block;">
      <div style="font-size: 2rem; margin-bottom: 0.75rem;">🗺️</div>
      <h2 style="font-size: 1.2rem; color: #1a1a2e; margin-bottom: 0.5rem;">State HOA Compliance Guides</h2>
      <p style="font-size: 0.9rem; color: #6b7280;">All 50 states. Find software that meets your state's specific HOA laws and compliance requirements.</p>
    </a>
  </div>
</BaseLayout>
