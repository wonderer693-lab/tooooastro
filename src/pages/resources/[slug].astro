---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import FAQSchema from '@components/FAQSchema.astro';
import { getResourceFaqs } from '@lib/faq-content';

const typeLabels: Record<string, string> = {
  glossary: "قاموس", faq: "أسئلة شائعة", template: "نموذج",
  "case-study": "دراسة حالة", checklist: "قائمة تقييم", statistics: "إحصائيات",
};

export async function getStaticPaths() {
  const resources = await getCollection('resource');
  return resources.map(r => ({ params: { slug: r.id }, props: { resource: r } }));
}

const { resource } = Astro.props;
const { data } = resource;
const typeLabel = typeLabels[data.type] || data.type;
const faqQuestions = data.type === 'faq' ? getResourceFaqs(resource.id) : [];
---

<BaseLayout title={`${data.title} - كلينك سا`} description={data.description}>
  {faqQuestions.length > 0 && <FAQSchema questions={faqQuestions} />}

  <main class="container" style="padding-top:var(--space-8);padding-bottom:var(--space-12);">
    <Breadcrumbs items={[
      { label: 'الرئيسية', href: '/' },
      { label: 'المصادر', href: '/resources/' },
      { label: data.title }
    ]} />

    <div style="margin-top:var(--space-4);">
      <h1>{data.title}</h1>
      <span class="badge badge-primary" style="margin-top:var(--space-2);">{typeLabel}</span>
    </div>

    <article class="card" style="margin-top:var(--space-6);">
      <div set:html={resource.body} />
    </article>
  </main>
</BaseLayout>
