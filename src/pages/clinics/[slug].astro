---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import ReviewCard from '@components/ReviewCard.astro';

export async function getStaticPaths() {
  const cats = await getCollection('category');
  return cats.map(c => ({ params: { slug: c.id }, props: { cat: c } }));
}

const { cat } = Astro.props;
const { data } = cat;
const reviews = await getCollection('review');
const cats = await getCollection('category');
---

<BaseLayout title={`${data.title} - كلينك سا`} description={data.description}>
  <main class="container" style="padding-top:var(--space-8);padding-bottom:var(--space-12);">
    <Breadcrumbs items={[
      { label: 'الرئيسية', href: '/' },
      { label: 'التصنيفات', href: '/clinics/' },
      { label: data.title }
    ]} />

    <h1 style="margin-top:var(--space-4);">{data.icon} {data.title}</h1>
    <p style="font-size:1.0625rem;color:var(--color-gray-500);">{data.description}</p>

    <div style="margin-top:var(--space-6);display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:var(--space-6);">
      {reviews.map(r => <ReviewCard review={r} />)}
    </div>
  </main>
</BaseLayout>
