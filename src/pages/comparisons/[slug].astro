---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import ComparisonTable from '@components/ComparisonTable.astro';

export async function getStaticPaths() {
  const comparisons = await getCollection('comparison');
  return comparisons.map(c => ({ params: { slug: c.id }, props: { comparison: c } }));
}

const { comparison } = Astro.props;
const { data } = comparison;
---

<BaseLayout title={`${data.title} - كلينك سا`} description={data.description}>
  <main class="container" style="padding-top:var(--space-8);padding-bottom:var(--space-12);">
    <Breadcrumbs items={[
      { label: 'الرئيسية', href: '/' },
      { label: 'المقارنات', href: '/comparisons/' },
      { label: data.title }
    ]} />

    <h1 style="margin-top:var(--space-4);">{data.title}</h1>
    <p style="font-size:1.0625rem;color:var(--color-gray-500);">{data.description}</p>

    <div style="display:flex;gap:var(--space-4);margin-top:var(--space-4);flex-wrap:wrap;">
      {data.tools.map(t => <span class="badge badge-primary">{t}</span>)}
      <span style="font-size:0.875rem;color:var(--color-gray-500);">التصنيف: {data.category}</span>
    </div>

    <div class="card" style="margin-top:var(--space-6);background:var(--color-green);color:var(--color-white);padding:var(--space-4);">
      <strong>الفائز: {data.winner}</strong>
      <p style="color:var(--color-white);margin:0;font-size:0.9375rem;">{data.winnerReason}</p>
    </div>

    <article class="card" style="margin-top:var(--space-6);">
      <div set:html={comparison.body} />
    </article>

    {data.tools.length >= 2 && (
      <section style="margin-top:var(--space-10);">
        <h2>جدول مقارنة المميزات</h2>
        <div style="margin-top:var(--space-4);">
          <ComparisonTable products={data.tools.map(t => {
            const slugMap: Record<string, string> = {
              "رعاية بلس": "riaya-plus", "غين": "gain", "كلينيكي": "clinicy",
              "أثير": "athir", "سلس": "sals-erp", "غايات": "ghayat",
              "إي كير بلاس": "ecare-plus", "ميدينوس": "medinous",
              "SimplePractice": "simplepractice", "Cliniko": "cliniko",
              "DrChrono": "drchrono", "Tebra": "tebra",
              "برامج سحابية": "clinicy", "برامج محلية": "athir",
            };
            return slugMap[t] || t;
          })} />
        </div>
      </section>
    )}
  </main>
</BaseLayout>
