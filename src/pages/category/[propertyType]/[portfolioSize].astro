---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SoftwareCard from '../../../components/SoftwareCard.astro';
import ComparisonTable from '../../../components/ComparisonTable.astro';
import AffiliateButton from '../../../components/AffiliateButton.astro';
import type { PropertyType, PortfolioSize, Software, State } from '../../../lib/types';
import {
  getSoftwareByPropertyType,
  getCategoryMeta,
  getCanonicalUrl,
  generateBreadcrumb,
  generateProductSchema,
  generateFAQSchema,
  generateSoftwareListSchema,
} from '../../../lib/utils';

export async function getStaticPaths() {
  const { default: propertyTypes } = await import('../../../data/property-types.json');
  const { default: portfolioSizes } = await import('../../../data/portfolio-sizes.json');
  const { default: softwareData } = await import('../../../data/software.json');
  const { default: statesData } = await import('../../../data/states.json');
  const software = softwareData as Software[];
  const states = statesData as State[];
  const paths = [];

  for (const pt of propertyTypes as PropertyType[]) {
    for (const ps of portfolioSizes as PortfolioSize[]) {
      const relevantSoftware = getSoftwareByPropertyType(software, pt.id)
        .filter((s: Software) => ps.minUnits >= s.portfolioSizeRange.min && (s.portfolioSizeRange.max === null || ps.maxUnits === null || ps.maxUnits! <= s.portfolioSizeRange.max!));
      if (relevantSoftware.length > 0) {
        paths.push({
          params: { propertyType: pt.slug, portfolioSize: ps.slug },
          props: { propertyType: pt, portfolioSize: ps, software: relevantSoftware, states },
        });
      }
    }
  }
  return paths;
}

const { propertyType, portfolioSize, software, states } = Astro.props;
const meta = getCategoryMeta(propertyType, portfolioSize);
const pageTitle = `${software[0]?.name} vs ${software[1]?.name ?? 'Others'}: Best ${propertyType.name} Software for ${portfolioSize.label} (${portfolioSize.minUnits}-${portfolioSize.maxUnits ?? '10000+'} Units) in 2026`;
const canonical = getCanonicalUrl(propertyType.slug, portfolioSize.slug);

// Uniqueness vectors
const avgCostPerUnit = portfolioSize.minUnits >= 1000 ? 1.50 : portfolioSize.minUnits >= 500 ? 2.00 : portfolioSize.minUnits >= 200 ? 3.00 : portfolioSize.minUnits >= 50 ? 4.50 : 6.00;
const estMonthlyCost = Math.round((portfolioSize.minUnits + (portfolioSize.maxUnits ?? portfolioSize.minUnits)) / 2 * avgCostPerUnit);
const topState = (states as State[]).find(s => s.litigationRisk === 'high' && s.popularSoftware.some(p => software.some(sw => sw.name.toLowerCase().includes(p.toLowerCase()))));
const relatedTypes = ['hoa', 'condo', 'mobile-home-park', 'str', 'commercial', 'student-housing'].filter(t => t !== propertyType.slug);
const totalComplianceBurden = (states as State[]).filter(s => s.reserveRequirements.includes('required') || s.managementLicenseRequired).length;

const faqs = [
  { question: `Which ${propertyType.name.toLowerCase()} software is best for ${portfolioSize.label.toLowerCase()}?`, answer: `${software[0]?.name ?? 'Our top pick'} leads for ${portfolioSize.label.toLowerCase()} due to its ${software[0]?.pros[0]?.toLowerCase() ?? 'feature set'} and ${portfolioSize.budgetRange} pricing. It handles ${propertyType.workflows.slice(0, 3).join(', ')} effectively at this scale.` },
  { question: `How much does ${propertyType.name.toLowerCase()} software cost for ${portfolioSize.minUnits} to ${portfolioSize.maxUnits ?? '10000+'} units?`, answer: `Monthly costs for ${portfolioSize.label.toLowerCase()} range from ${portfolioSize.budgetRange}. For a ${portfolioSize.minUnits}-unit ${propertyType.name.toLowerCase()}, plan on $${avgCostPerUnit.toFixed(2)}/unit/month or approximately $${estMonthlyCost}/month total for software.` },
  { question: `What features matter most for ${portfolioSize.label.toLowerCase()} ${propertyType.name.toLowerCase()}?`, answer: `${portfolioSize.requiredFeatures.slice(0, 5).join(', ')}. These directly address the top pain points for ${portfolioSize.buyerProfile.toLowerCase()}.` },
  { question: `Can volunteers or self-managed ${propertyType.name.toLowerCase()}s use these tools?`, answer: `${software.filter(s => s.pricing.startingPrice < 100).length > 0 ? 'Yes — ' + software.filter(s => s.pricing.startingPrice < 100).map(s => s.name).join(', ') + ' offer affordable options' : 'Most tools at this scale are designed for professional managers'}.` },
  { question: `How long does onboarding take for ${portfolioSize.label.toLowerCase()}?`, answer: software.map(s => `${s.name}: ${s.onboarding.toLowerCase()}`).join('; ') + '. Self-service platforms take 1-3 days; enterprise solutions need 4-12 weeks.' },
];

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: `${propertyType.name} Software`, url: `/category/${propertyType.slug}/${portfolioSize.slug}/` },
  { name: portfolioSize.label, url: `/category/${propertyType.slug}/${portfolioSize.slug}/` },
];

const breadcrumbSchema = generateBreadcrumb(breadcrumbItems);
const faqSchema = generateFAQSchema(faqs);
const listSchema = generateSoftwareListSchema(software.map(s => ({
  name: s.name,
  url: canonical,
  description: s.tagline,
})));
const midString = portfolioSize.label.toLowerCase();
---

<BaseLayout title={pageTitle} description={meta.description} canonical={canonical} schema={[breadcrumbSchema, faqSchema, listSchema]}>
  <div slot="hero" class="hero">
    <div class="wrapper">
      <h1>{pageTitle}</h1>
      <p>{propertyType.description.slice(0, 100)}... We analyzed <strong>{software.length} platforms</strong> for {propertyType.name.toLowerCase()} managers running portfolios of <strong>{portfolioSize.minUnits}-{portfolioSize.maxUnits ?? '10000+'} units</strong>.</p>
    </div>
  </div>

  <div slot="breadcrumbs">
    <a href="/">Home</a> &raquo; <a href="/">{propertyType.name} Software</a> &raquo; {portfolioSize.label}
  </div>

  <div class="affiliate-disclosure">
    We may earn commissions if you purchase through our affiliate links. Our reviews and comparisons are based on independent testing with 22-point feature analysis and 15+ years of property management experience.
  </div>

  <div class="last-updated">
    <strong>Last updated:</strong> June 14, 2026 &middot; <strong>Reviewed by:</strong> <a href="/about/methodology/">Property Management Technology Team</a>
  </div>

  <div class="quick-verdict" style="position: relative;">
    <span class="editors-badge">EDITOR'S CHOICE</span>
    <h3>Quick Verdict</h3>
    <p><strong>{software[0]?.name ?? 'N/A'}</strong> is our top pick for {propertyType.name.toLowerCase()} management for <strong>{portfolioSize.label.toLowerCase()}</strong>. {software[0]?.pros[0] ?? 'Best-in-class feature set.'} At <strong>{'$'}{software[0]?.pricing.startingPrice ?? 'N/A'}/mo</strong>, it fits the {portfolioSize.budgetRange} budget typical for this size. {topState ? 'Note: If you operate in ' + topState.name + ', ensure your software handles ' + topState.reserveRequirements.toLowerCase() + ' — ' + (software[0]?.name ?? 'your chosen platform') + ' ' + (software[0]?.features.reserveStudies ? 'supports this' : 'may need supplementing for this requirement') + '.' : ''}</p>
    <AffiliateButton software={software[0]} label={`Try ${software[0]?.name} Free`} />
  </div>

  <section>
    <h2>Why {portfolioSize.label} {propertyType.name} Management Is Different</h2>
    <p>Managing a {propertyType.name.toLowerCase()} for <strong>{midString}</strong> is not the same as running one with 5 units or 5,000 units. {portfolioSize.buyerProfile} face constraints that off-the-shelf tools don't solve.</p>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value">{portfolioSize.minUnits}-{portfolioSize.maxUnits ?? '10000+'}</div>
        <div class="stat-label">Unit Range</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{portfolioSize.budgetRange}</div>
        <div class="stat-label">Monthly Budget</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">~{estMonthlyCost.toLocaleString()}/mo</div>
        <div class="stat-label">Est. Total Cost</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{'$'}{totalComplianceBurden}</div>
        <div class="stat-label">States With Reserve Mandates</div>
      </div>
    </div>

    <h3>Top {software.length} Pain Points</h3>
    <ol class="pain-point-list">
      {portfolioSize.painPoints.slice(0, 5).map((p, i) => (
        <li><strong>{(software[i % software.length]?.name ?? 'Generic')} addresses this:</strong> {p}</li>
      ))}
    </ol>

    <h3>Cost Reality Check</h3>
    <p>At ~<strong>{'$'}{avgCostPerUnit.toFixed(2)}/unit/month</strong>, a {portfolioSize.minUnits}-unit {propertyType.name.toLowerCase()} pays roughly <strong>{'$'}{estMonthlyCost.toLocaleString()}/month</strong> for a capable platform. {software[0]?.pricing.startingPrice < (portfolioSize.minUnits * avgCostPerUnit) ? 'Most top-tier options come in under this estimate.' : 'Budget-conscious buyers should focus on flat-rate or per-property pricing models.'}</p>
  </section>

  <section>
    <h2>Top {software.length} Best {propertyType.name} Software for {portfolioSize.label}</h2>
    <div class="software-grid">
      {software.map(s => <SoftwareCard software={s} />)}
    </div>
  </section>

  <section>
    <h2>Feature Comparison: {software.map(s => s.name).join(' vs ')}</h2>
    <p>22-point feature matrix tailored for {propertyType.name.toLowerCase()} management at the {midString} scale.</p>
    <ComparisonTable software={software} />
  </section>

  <section>
    <h2>Decision Framework: Which {propertyType.name} Software for {portfolioSize.label}?</h2>
    <div class="decision-grid">
      {software.map(s => (
        <div class="decision-card">
          <h3>{s.name}</h3>
          <div class="verdict-badge">{software.indexOf(s) === 0 ? 'Best Overall' : software.indexOf(s) === 1 ? 'Runner Up' : 'Also Great'}</div>
          <p class="for-label"><strong>Best for:</strong> {s.idealCustomer}</p>
          <p class="price-label">{'$'}{s.pricing.startingPrice}/mo &middot; {s.onboarding}</p>
          <a href={`/software/${s.slug}/`}>Review &rarr;</a>
        </div>
      ))}
    </div>
  </section>

  <section>
    <h2>How to Choose: Buying Guide for {portfolioSize.label} {propertyType.name} Software</h2>
    <p>Use this checklist when evaluating platforms:</p>
    <ol class="checklist">
      <li><strong>Budget check:</strong> {portfolioSize.budgetRange} — eliminate anything outside this range</li>
      <li><strong>Must-have features:</strong> {portfolioSize.requiredFeatures.slice(0, 5).join(', ')}</li>
      <li><strong>Integration priority:</strong> QuickBooks Online vs Desktop vs Xero — choose a platform that matches your stack</li>
      <li><strong>Onboarding timeline:</strong> {software.map(s => `${s.name}: ${s.onboarding}`).join('; ')}</li>
      <li><strong>Compliance:</strong> {topState ? `If in ${topState.name}, verify ${topState.reserveRequirements.toLowerCase()} support` : 'Check your state reserve study requirements'}</li>
    </ol>
  </section>

  <section>
    <h2>Related {propertyType.name} Software Guides</h2>
    <div class="related-grid">
      <div class="related-card">Small: <a href={`/category/${propertyType.slug}/under-50-units/`}>&lt;50 units</a></div>
      <div class="related-card">Medium: <a href={`/category/${propertyType.slug}/50-200-units/`}>50-200 units</a></div>
      <div class="related-card">Large: <a href={`/category/${propertyType.slug}/200-500-units/`}>200-500 units</a></div>
      <div class="related-card">Enterprise: <a href={`/category/${propertyType.slug}/500-1000-units/`}>500-1000 units</a></div>
      <div class="related-card">Mega: <a href={`/category/${propertyType.slug}/1000-plus-units/`}>1000+ units</a></div>
    </div>

    <h3>Compare by Property Type</h3>
    <div class="related-grid">
      {relatedTypes.map(t => {
        const names = { hoa: 'HOA', condo: 'Condo', 'mobile-home-park': 'Mobile Home Park', str: 'Vacation Rental', commercial: 'Commercial', 'student-housing': 'Student Housing' };
        return <div class="related-card"><a href={`/category/${t}/${portfolioSize.slug}/`}>{names[t] ?? t} ({midString})</a></div>;
      })}
    </div>
  </section>

  <section class="faq-section">
    <h2>Frequently Asked Questions</h2>
    {faqs.map(f => (
      <div class="faq-item" itemscope itemtype="https://schema.org/Question">
        <h4 itemprop="name">{f.question}</h4>
        <div itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
          <p itemprop="text">{f.answer}</p>
        </div>
      </div>
    ))}
  </section>

  <section class="cta-section">
    <h3>Ready to Find the Perfect {propertyType.name} Software?</h3>
    <p>Compare {software.length} platforms side by side. Your {portfolioSize.label.toLowerCase()} portfolio needs the right tools.</p>
    <a href={software[0]?.affiliateUrl ?? '#'} target="_blank" rel="nofollow sponsored noopener" class="cta-btn-large">Start with {software[0]?.name ?? 'Top Platform'} →</a>
  </section>

  <div class="disclosure">
    <strong>Affiliate Disclosure:</strong> PropertyManagePro is reader-supported. When you click through links on our site and make a purchase, we may earn a commission. Our reviews and comparisons are based on independent research and analysis. We only recommend software we believe provides genuine value to property managers and association boards.
  </div>
</BaseLayout>

<style>
  .last-updated { font-size: 0.85rem; color: #6b7280; margin-bottom: 1.5rem; padding: 0.5rem 1rem; background: #f9fafb; border-radius: 6px; display: inline-block; }
  .editors-badge { position: absolute; top: -0.5rem; right: 1rem; background: #dc2626; color: white; padding: 0.2rem 0.75rem; border-radius: 0 0 6px 6px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
  .stat-card { background: white; padding: 1.25rem; border-radius: 10px; border: 1px solid #e5e7eb; text-align: center; }
  .stat-value { font-size: 1.5rem; font-weight: 800; color: #1a1a2e; }
  .stat-label { font-size: 0.85rem; color: #6b7280; margin-top: 0.25rem; }
  .pain-point-list { list-style: decimal; padding-left: 1.5rem; }
  .pain-point-list li { margin-bottom: 0.75rem; padding-left: 0.5rem; }
  .decision-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; margin: 1.5rem 0; }
  .decision-card { background: white; padding: 1.5rem; border-radius: 10px; border: 1px solid #e5e7eb; position: relative; }
  .verdict-badge { display: inline-block; background: #eff6ff; color: #2563eb; padding: 0.15rem 0.6rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.75rem; }
  .for-label { font-size: 0.9rem; margin-bottom: 0.5rem; }
  .price-label { font-size: 0.85rem; color: #6b7280; }
  .checklist { list-style: none; padding: 0; }
  .checklist li { padding: 0.75rem 1rem; margin-bottom: 0.5rem; background: white; border-radius: 8px; border: 1px solid #e5e7eb; counter-increment: step; }
  .checklist li::before { content: counter(step); background: #1a1a2e; color: white; width: 24px; height: 24px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; margin-right: 0.75rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.75rem; margin: 1rem 0; }
  .related-card { background: white; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid #e5e7eb; font-size: 0.9rem; text-align: center; }
</style>
