---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SoftwareCard from '../../../components/SoftwareCard.astro';
import ComparisonTable from '../../../components/ComparisonTable.astro';
import AffiliateButton from '../../../components/AffiliateButton.astro';
import type { PropertyType, PortfolioSize, Software } from '../../../lib/types';
import {
  getSoftwareByPropertyType,
  getSoftwareByPortfolioSize,
  getCategoryMeta,
  getPageTitleH1,
  getCanonicalUrl,
  generateBreadcrumb,
  generateProductSchema,
  generateFAQSchema,
  generateSoftwareListSchema,
} from '../../../lib/utils';

export async function getStaticPaths() {
  const { default: propertyTypes } = await import('../../../data/property-types.json');
  const { default: portfolioSizes } = await import('../../../data/portfolio-sizes.json');
  const { default: softwareData } = await import('../../../data/software.json');

  const software = softwareData as Software[];
  const paths: { params: { propertyType: string; portfolioSize: string }; props: { propertyType: PropertyType; portfolioSize: PortfolioSize; software: Software[] } }[] = [];

  for (const pt of propertyTypes as PropertyType[]) {
    for (const ps of portfolioSizes as PortfolioSize[]) {
      const relevantSoftware = getSoftwareByPropertyType(software, pt.id)
        .filter(s => ps.minUnits >= s.portfolioSizeRange.min && (s.portfolioSizeRange.max === null || ps.maxUnits === null || ps.maxUnits! <= s.portfolioSizeRange.max!));
      if (relevantSoftware.length > 0) {
        paths.push({
          params: { propertyType: pt.slug, portfolioSize: ps.slug },
          props: { propertyType: pt, portfolioSize: ps, software: relevantSoftware },
        });
      }
    }
  }
  return paths;
}

const { propertyType, portfolioSize, software } = Astro.props;
const meta = getCategoryMeta(propertyType, portfolioSize);
const pageTitle = `Best ${propertyType.name} Software for ${portfolioSize.label} (${portfolioSize.minUnits}-${portfolioSize.maxUnits ?? '10000+'} Units) in 2026`;
const canonical = getCanonicalUrl(propertyType.slug, portfolioSize.slug);

const faqs = [
  { question: `What is the best ${propertyType.name.toLowerCase()} management software for ${portfolioSize.label.toLowerCase()}?`, answer: `Based on our analysis, ${software[0]?.name ?? 'the top platform below'} is the best ${propertyType.name.toLowerCase()} management software for portfolios ${portfolioSize.label.toLowerCase()}. It excels in ${(software[0]?.pros[0] ?? 'features').toLowerCase()} and is trusted by similar-sized organizations.` },
  { question: `How much does ${propertyType.name.toLowerCase()} management software cost for ${portfolioSize.label.toLowerCase()}?`, answer: `For portfolios ${portfolioSize.label.toLowerCase()}, pricing typically ranges from ${portfolioSize.budgetRange}. Most providers offer tiered pricing based on unit count and feature requirements.` },
  { question: `What features should I look for in ${propertyType.name.toLowerCase()} software for ${portfolioSize.label.toLowerCase()}?`, answer: `Key features include: ${portfolioSize.requiredFeatures.slice(0, 5).join(', ')}. These are essential for ${portfolioSize.buyerProfile.toLowerCase()}.` },
  { question: `Can self-managed ${propertyType.name.toLowerCase()} associations use professional software?`, answer: `Yes. Many providers like ${software.filter(s => s.pricing.startingPrice < 100).map(s => s.name).slice(0, 2).join(' and ')} offer affordable plans designed for volunteer boards and self-managed associations.` },
  { question: `How long does it take to implement new ${propertyType.name.toLowerCase()} management software?`, answer: `Implementation timelines vary: self-service tools take 1-3 days, while enterprise solutions like ${software.find(s => s.pricing.startingPrice > 200)?.name ?? 'AppFolio'} require 6-12 weeks for full deployment.` },
];

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: `${propertyType.name} Software`, url: `/category/${propertyType.slug}/${portfolioSize.slug}/` },
  { name: portfolioSize.label, url: `/category/${propertyType.slug}/${portfolioSize.slug}/` },
];

const breadcrumbSchema = generateBreadcrumb(breadcrumbItems);
const faqSchema = generateFAQSchema(faqs);
const listSchema = generateSoftwareListSchema(software.map(s => ({
  name: s.name,
  url: canonical,
  description: s.tagline,
})));
---

<BaseLayout title={pageTitle} description={meta.description} canonical={canonical} schema={[breadcrumbSchema, faqSchema, listSchema]}>
  <div slot="hero" class="hero">
    <div class="wrapper">
      <h1>{pageTitle}</h1>
      <p>{propertyType.description.slice(0, 120)}... We compare the top solutions for {propertyType.name.toLowerCase()} managers with {portfolioSize.label.toLowerCase()} to help you find the perfect fit.</p>
    </div>
  </div>

  <div slot="breadcrumbs">
    <a href="/">Home</a> &raquo; <a href="/">{propertyType.name} Software</a> &raquo; {portfolioSize.label}
  </div>

  <div class="affiliate-disclosure">
    We may earn commissions if you purchase through our affiliate links. Our reviews are independent and based on expert analysis.
  </div>

  <div class="quick-verdict">
    <h3>Quick Verdict</h3>
    <p><strong>{software[0]?.name ?? 'N/A'}</strong> is our top pick for {propertyType.name.toLowerCase()} management for {portfolioSize.label.toLowerCase()}. {software[0]?.pros[0] ?? 'It offers excellent features and value.'} {portfolioSize.budgetRange && `Pricing starts within the ${portfolioSize.budgetRange} range, making it accessible for ${portfolioSize.buyerProfile.toLowerCase()}.`}</p>
    <AffiliateButton software={software[0]} label={`Try ${software[0]?.name} Free`} />
  </div>

  <section>
    <h2>Why You Need Specialized {propertyType.name} Software for {portfolioSize.label}</h2>
    <p>Managing a {propertyType.name.toLowerCase()} for <strong>{portfolioSize.label.toLowerCase()}</strong> comes with unique challenges. {portfolioSize.buyerProfile} face specific pain points that general property management tools don't address.</p>

    <h3>Common Pain Points</h3>
    <ul>
      {portfolioSize.painPoints.map(p => <li>{p}</li>)}
    </ul>

    <h3>Key {propertyType.name} Workflows to Consider</h3>
    <ul>
      {propertyType.workflows.slice(0, 6).map(w => <li><strong>{w}</strong></li>)}
    </ul>
  </section>

  <section>
    <h2>Top {software.length} Best {propertyType.name} Software for {portfolioSize.label} Compared</h2>
    <div class="software-grid">
      {software.map(s => <SoftwareCard software={s} />)}
    </div>
  </section>

  <section>
    <h2>Feature Comparison Table</h2>
    <p>Side-by-side comparison of key features across the top {propertyType.name.toLowerCase()} management platforms for {portfolioSize.label.toLowerCase()}.</p>
    <ComparisonTable software={software} />
  </section>

  <section>
    <h2>Who Should Use What: Decision Guide</h2>
    {software.map(s => (
      <div style="margin-bottom: 1.5rem;">
        <h3>{s.name}</h3>
        <p><strong>Ideal for:</strong> {s.idealCustomer}</p>
        <p><strong>Not ideal for:</strong> {s.notIdealFor.join(', ')}</p>
        <p><strong>Starting price:</strong> ${s.pricing.startingPrice}/mo ({s.pricing.pricingModel.replace('-', ' ')} pricing). {s.pricing.freeTrial ? 'Free trial available.' : ''}</p>
        <a href={`/software/${s.slug}/`}>Read full {s.name} review</a>
      </div>
    ))}
  </section>

  <section>
    <h2>How to Choose the Right {propertyType.name} Software for {portfolioSize.label}</h2>
    <p>Follow this checklist when evaluating {propertyType.name.toLowerCase()} management software for a {portfolioSize.label.toLowerCase()} portfolio:</p>
    <ol>
      <li><strong>Start with your budget:</strong> {portfolioSize.budgetRange} is the typical range for your portfolio size</li>
      <li><strong>Prioritize must-have features:</strong> {portfolioSize.requiredFeatures.slice(0, 4).join(', ')}</li>
      <li><strong>Consider your buyer profile:</strong> {portfolioSize.buyerProfile}</li>
      <li><strong>Check integrations:</strong> QuickBooks sync and bank lockbox are critical</li>
      <li><strong>Evaluate onboarding:</strong> Look for providers with ({software.map(s => s.name + ': ' + s.onboarding).join(', ')})</li>
    </ol>
  </section>

  <section class="faq-section">
    <h2>Frequently Asked Questions</h2>
    {faqs.map(f => (
      <div class="faq-item">
        <h4>{f.question}</h4>
        <p>{f.answer}</p>
      </div>
    ))}
  </section>

  <section class="cta-section">
    <h3>Ready to Find the Perfect {propertyType.name} Software?</h3>
    <p>Compare top platforms side by side and find the best solution for your {portfolioSize.label.toLowerCase()} portfolio.</p>
    <a href={software[0]?.affiliateUrl ?? '#'} target="_blank" rel="nofollow sponsored noopener" class="cta-btn-large">Get Started with {software[0]?.name ?? 'Top Platform'} →</a>
  </section>

  <div class="disclosure">
    <strong>Affiliate Disclosure:</strong> PropertyManagePro is reader-supported. When you click through links on our site and make a purchase, we may earn a commission. Our reviews and comparisons are based on independent research and analysis. We only recommend software we believe provides genuine value to property managers and association boards.
  </div>
</BaseLayout>
