---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ReviewCard from '@components/ReviewCard.astro';

const reviews = await getCollection('review');
reviews.sort((a, b) => b.data.rating - a.data.rating);
const topRated = reviews.slice(0, 6);
const comparisons = await getCollection('comparison');
const compFeat = comparisons.filter(c => c.data.featured).slice(0, 3);
const guides = await getCollection('guide');
const guideFeat = guides.filter(g => g.data.featured).slice(0, 3);
---

<BaseLayout title="كلينك سا - أفضل برامج إدارة العيادات في السعودية" description="دليلك الشامل لأفضل برامج إدارة العيادات الطبية في السعودية. مراجعات، مقارنات، وأدلة شراء لاختيار النظام المناسب">
  <style>
    .hero { background: linear-gradient(135deg, var(--color-primary) 0%, #0f766e 100%); color: var(--color-white); padding: var(--space-16) 0; }
    .hero h1 { font-size: 2.5rem; margin-bottom: var(--space-4); }
    .hero p { font-size: 1.125rem; opacity: 0.9; margin-bottom: var(--space-6); }
    .hero .btn-outline { border-color: var(--color-white); color: var(--color-white); }
    .hero .btn-outline:hover { background: var(--color-white); color: var(--color-primary); }
    .hero-stats { display: flex; gap: var(--space-8); margin-top: var(--space-8); }
    .hero-stats div { text-align: center; }
    .hero-stats strong { font-size: 1.75rem; display: block; }
    .hero-stats span { font-size: 0.875rem; opacity: 0.8; }
    .section-title { margin-bottom: var(--space-6); }
    @media (max-width: 768px) {
      .hero h1 { font-size: 1.75rem; }
      .hero-stats { gap: var(--space-4); }
    }
  </style>

  <section class="hero">
    <div class="container">
      <h1>أفضل برامج إدارة العيادات في السعودية</h1>
      <p>دليلك الشامل لاختيار نظام إدارة العيادات المناسب. مراجعات دقيقة ومقارنات عادلة لـ {reviews.length} برنامج.</p>
      <div style="display:flex;gap:var(--space-4);flex-wrap:wrap;">
        <a href="/software/" class="btn btn-lg" style="background:var(--color-white);color:var(--color-primary);font-weight:700;">استعرض البرامج</a>
        <a href="/comparisons/" class="btn btn-lg btn-outline">قارن بين البرامج</a>
      </div>
      <div class="hero-stats">
        <div><strong>{reviews.length}</strong><span>برنامج</span></div>
        <div><strong>{comparisons.length}</strong><span>مقارنة</span></div>
        <div><strong>{guides.length}</strong><span>دليل شراء</span></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">أفضل البرامج المقيمة</h2>
      <div class="grid" style="grid-template-columns:repeat(auto-fill,minmax(320px,1fr));">
        {topRated.map(r => <ReviewCard review={r} />)}
      </div>
      <div style="text-align:center;margin-top:var(--space-8);">
        <a href="/software/" class="btn btn-outline">عرض جميع البرامج</a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">مقارنات مميزة</h2>
      <div style="display:grid;gap:var(--space-6);">
        {compFeat.map(c => (
          <a href={`/comparisons/${c.id}/`} class="card" style="display:block;color:inherit;">
            <h3>{c.data.title}</h3>
            <p style="color:var(--color-gray-500);font-size:0.9375rem;">{c.data.description}</p>
            <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;margin-top:var(--space-2);">
              {c.data.tools.map(t => <span style="background:var(--color-gray-100);padding:var(--space-1) var(--space-3);border-radius:999px;font-size:0.8125rem;">{t}</span>)}
            </div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:var(--space-6);">
        <a href="/comparisons/" class="btn btn-outline">عرض جميع المقارنات</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">أدلة شراء</h2>
      <div style="display:grid;gap:var(--space-6);">
        {guideFeat.map(g => (
          <a href={`/guides/${g.id}/`} class="card" style="display:block;color:inherit;">
            <h3>{g.data.title}</h3>
            <p style="color:var(--color-gray-500);font-size:0.9375rem;">{g.data.description}</p>
            <div style="display:flex;gap:var(--space-2);margin-top:var(--space-2);font-size:0.875rem;color:var(--color-gray-500);">
              <span class="badge badge-primary">{g.data.category}</span>
              <span>{g.data.readingTime}</span>
            </div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:var(--space-6);">
        <a href="/guides/" class="btn btn-outline">عرض جميع الأدلة</a>
      </div>
    </div>
  </section>
</BaseLayout>
