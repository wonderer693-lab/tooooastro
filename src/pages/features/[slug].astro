---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';

export async function getStaticPaths() {
  const features = await getCollection('feature');
  return features.map(f => ({ params: { slug: f.id }, props: { feature: f } }));
}

const { feature } = Astro.props;
const { data } = feature;
---

<BaseLayout title={`${data.title} - كلينك سا`} description={data.description}>
  <main class="container" style="padding-top:var(--space-8);padding-bottom:var(--space-12);">
    <Breadcrumbs items={[
      { label: 'الرئيسية', href: '/' },
      { label: 'المميزات', href: '/features/' },
      { label: data.title }
    ]} />

    <h1 style="margin-top:var(--space-4);">{data.title}</h1>
    <p style="font-size:1.0625rem;color:var(--color-gray-500);">{data.description}</p>

    <span class="badge badge-primary" style="margin-top:var(--space-2);">{data.category}</span>

    <article class="card" style="margin-top:var(--space-6);">
      <div set:html={feature.body} />
    </article>
  </main>
</BaseLayout>
