---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  lastUpdated?: string;
}

const { title, description, canonical, schema, lastUpdated } = Astro.props;
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const authorSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "PropertyManagePro Editorial Team",
  "description": "Property management software experts with 15+ years in real estate technology",
  "url": "https://www.propertymanagepro.com/about/"
};
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "PropertyManagePro",
  "url": "https://www.propertymanagepro.com",
  "description": "Expert property management software reviews and comparisons"
};
const allSchemas = [authorSchema, orgSchema, ...schemas];
---

<!DOCTYPE html>
<html lang="en-us">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}
  <meta name="robots" content="index, follow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #1a1a2e; background: #f8f9fa; min-height: 100vh; display: flex; flex-direction: column; }
    a { color: #2563eb; text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; height: auto; }
    .wrapper { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; width: 100%; }
    header { background: #1a1a2e; color: white; padding: 1rem 0; border-bottom: 3px solid #059669; }
    header .wrapper { display: flex; justify-content: space-between; align-items: center; }
    header a { color: white; }
    .logo { font-size: 1.4rem; font-weight: 800; letter-spacing: -0.5px; }
    .logo span { color: #059669; }
    nav a { margin-left: 1.5rem; font-size: 0.9rem; }
    nav a:hover { color: #059669; text-decoration: none; }
    .hero { background: linear-gradient(135deg, #1a1a2e 0%, #2563eb 100%); color: white; padding: 3rem 0; text-align: center; }
    .hero h1 { font-size: 2.5rem; margin-bottom: 1rem; line-height: 1.2; }
    .hero p { font-size: 1.15rem; opacity: 0.9; max-width: 700px; margin: 0 auto 1.5rem; }
    .breadcrumbs { padding: 1rem 0; font-size: 0.85rem; color: #6b7280; }
    .breadcrumbs a { color: #6b7280; }
    .breadcrumbs a:hover { color: #2563eb; }
    main { flex: 1; padding: 2rem 0; }
    .page-content h2 { font-size: 1.75rem; margin: 2rem 0 1rem; color: #1a1a2e; }
    .page-content h3 { font-size: 1.25rem; margin: 1.5rem 0 0.75rem; color: #374151; }
    .page-content p { margin-bottom: 1rem; color: #4b5563; }
    .page-content ul { margin: 1rem 0; padding-left: 1.5rem; }
    .page-content li { margin-bottom: 0.5rem; color: #4b5563; }
    .quick-verdict { background: #ecfdf5; border-left: 4px solid #059669; padding: 1.5rem; border-radius: 8px; margin: 1.5rem 0; position: relative; }
    .quick-verdict h3 { margin-top: 0; }
    .software-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1.5rem; margin: 2rem 0; }
    .faq-section { background: white; border-radius: 12px; padding: 2rem; margin: 2rem 0; border: 1px solid #e5e7eb; }
    .faq-item { border-bottom: 1px solid #f0f0f0; padding: 1rem 0; }
    .faq-item:last-child { border-bottom: none; }
    .faq-item h4 { font-size: 1rem; margin-bottom: 0.5rem; color: #1a1a2e; }
    .faq-item p { font-size: 0.95rem; color: #6b7280; }
    .cta-section { background: #1a1a2e; color: white; padding: 2rem; border-radius: 12px; text-align: center; margin: 2rem 0; }
    .cta-section h3 { color: white; margin-bottom: 0.5rem; }
    .cta-section p { color: #9ca3af; margin-bottom: 1.5rem; }
    .cta-btn-large { display: inline-block; padding: 1rem 2.5rem; background: #059669; color: white; border-radius: 8px; font-weight: 700; font-size: 1.1rem; }
    .cta-btn-large:hover { background: #047857; text-decoration: none; }
    .author-box { display: flex; gap: 1rem; align-items: center; padding: 1.25rem; background: white; border-radius: 10px; border: 1px solid #e5e7eb; margin: 2rem 0; }
    .author-avatar { width: 48px; height: 48px; background: linear-gradient(135deg, #059669, #2563eb); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.1rem; flex-shrink: 0; }
    .author-info { font-size: 0.9rem; }
    .author-info strong { display: block; color: #1a1a2e; }
    .author-info span { color: #6b7280; font-size: 0.85rem; }
    footer { background: #1a1a2e; color: #9ca3af; padding: 2rem 0; margin-top: auto; font-size: 0.85rem; text-align: center; }
    footer a { color: #9ca3af; }
    footer a:hover { color: white; }
    .disclosure { font-size: 0.8rem; color: #6b7280; margin-top: 1rem; padding: 1rem; background: #f9fafb; border-radius: 8px; }
    .affiliate-disclosure { background: #fffbeb; border: 1px solid #fde68a; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.85rem; color: #92400e; margin-bottom: 1.5rem; }
    .last-updated { font-size: 0.85rem; color: #6b7280; margin-bottom: 1.5rem; padding: 0.5rem 1rem; background: #f9fafb; border-radius: 6px; display: inline-block; }
    .editors-badge { position: absolute; top: -0.5rem; right: 1rem; background: #dc2626; color: white; padding: 0.2rem 0.75rem; border-radius: 0 0 6px 6px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .stat-card { background: white; padding: 1.25rem; border-radius: 10px; border: 1px solid #e5e7eb; text-align: center; }
    .stat-value { font-size: 1.5rem; font-weight: 800; color: #1a1a2e; }
    .stat-label { font-size: 0.85rem; color: #6b7280; margin-top: 0.25rem; }
    .decision-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; margin: 1.5rem 0; }
    .decision-card { background: white; padding: 1.5rem; border-radius: 10px; border: 1px solid #e5e7eb; position: relative; }
    .decision-card h3 { margin-top: 0; }
    .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.75rem; margin: 1rem 0; }
    .related-card { background: white; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid #e5e7eb; font-size: 0.9rem; text-align: center; }
    .checklist { list-style: none; padding: 0; }
    .checklist li { padding: 0.75rem 1rem; margin-bottom: 0.5rem; background: white; border-radius: 8px; border: 1px solid #e5e7eb; display: flex; align-items: center; gap: 0.75rem; }
    .checklist li::before { content: counter(step); counter-increment: step; background: #1a1a2e; color: white; width: 24px; height: 24px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; flex-shrink: 0; }
    .pain-point-list { list-style: decimal; padding-left: 1.5rem; }
    .pain-point-list li { margin-bottom: 0.75rem; padding-left: 0.5rem; }
    @media (max-width: 768px) {
      .hero h1 { font-size: 1.8rem; }
      .hero p { font-size: 1rem; }
      .software-grid { grid-template-columns: 1fr; }
      header .wrapper { flex-direction: column; gap: 0.75rem; }
      nav a { margin: 0 0.75rem; }
    }
  </style>
  {allSchemas.map(s => <script type="application/ld+json" set:html={JSON.stringify(s)}></script>)}
</head>
<body>
  <header>
    <div class="wrapper">
      <a href="/" class="logo"><span>Property</span>ManagePro</a>
      <nav>
        <a href="/">Home</a>
        <a href="/category/hoa/under-50-units/">HOA</a>
        <a href="/category/condo/under-50-units/">Condo</a>
        <a href="/category/vacation-rental/under-50-units/">STR</a>
        <a href="/category/commercial/under-50-units/">Commercial</a>
        <a href="/about/">About</a>
        <a href="/methodology/">Methodology</a>
      </nav>
    </div>
  </header>

  <slot name="hero" />

  {Astro.slots.has('breadcrumbs') && (
    <div class="breadcrumbs">
      <div class="wrapper">
        <slot name="breadcrumbs" />
      </div>
    </div>
  )}

  <main>
    <div class="wrapper page-content">
      {lastUpdated && <div class="last-updated"><strong>Last updated:</strong> {lastUpdated}</div>}
      <slot />
    </div>
  </main>

  <footer>
    <div class="wrapper">
      <p><a href="/">PropertyManagePro</a> &mdash; Expert property management software comparisons since 2025</p>
      <p style="margin-top: 0.5rem;">
        <a href="/category/hoa/under-50-units/">HOA Software</a> &middot;
        <a href="/category/condo/under-50-units/">Condo Software</a> &middot;
        <a href="/category/vacation-rental/under-50-units/">STR Software</a> &middot;
        <a href="/category/commercial/under-50-units/">Commercial Software</a> &middot;
        <a href="/about/">About</a> &middot;
        <a href="/methodology/">Methodology</a> &middot;
        <a href="/resources/">Resources</a>
      </p>
    </div>
  </footer>
</body>
</html>
