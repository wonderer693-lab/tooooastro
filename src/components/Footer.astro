<style>
.site-footer {
  background: var(--color-gray-900); color: var(--color-gray-300);
  padding: var(--space-12) 0 var(--space-6);
  margin-top: var(--space-16);
}
.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: var(--space-8); }
.footer-col h3 { color: var(--color-white); font-size: 1.125rem; margin-bottom: var(--space-3); }
.footer-col h4 { color: var(--color-white); font-size: 0.9375rem; margin-bottom: var(--space-3); }
.footer-col p { font-size: 0.875rem; }
.footer-col ul { list-style: none; padding: 0; margin: 0; }
.footer-col li { margin-bottom: var(--space-2); }
.footer-col a { color: var(--color-gray-400); font-size: 0.875rem; }
.footer-col a:hover { color: var(--color-white); }
.footer-bottom { margin-top: var(--space-8); padding-top: var(--space-6); border-top: 1px solid var(--color-gray-700); }
.footer-bottom p { font-size: 0.8125rem; color: var(--color-gray-500); }
@media (max-width: 768px) {
  .footer-grid { grid-template-columns: 1fr 1fr; }
}
</style>
