---
import type { Software } from '../lib/types';

interface Props {
  software: Software;
  label?: string;
  variant?: 'primary' | 'secondary';
}

const { software, label, variant = 'primary' } = Astro.props;
const btnLabel = label ?? `Try ${software.name} Free`;
const siteName = 'PropertyManagePro';
---

<a
  href={software.affiliateUrl}
  target="_blank"
  rel="nofollow sponsored noopener"
  class={`affiliate-btn ${variant}`}
>
  {btnLabel}
</a>

<style>
  .affiliate-btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }
  .affiliate-btn:hover { transform: translateY(-1px); text-decoration: none; }
  .affiliate-btn.primary {
    background: #059669;
    color: white;
    box-shadow: 0 2px 8px rgba(5, 150, 105, 0.3);
  }
  .affiliate-btn.primary:hover { background: #047857; box-shadow: 0 4px 12px rgba(5, 150, 105, 0.4); }
  .affiliate-btn.secondary {
    background: white;
    color: #1a1a2e;
    border: 2px solid #e5e7eb;
  }
  .affiliate-btn.secondary:hover { border-color: #059669; color: #059669; }
</style>
