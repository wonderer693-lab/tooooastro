---
export interface Crumb {
  label: string;
  href?: string;
}

export interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="مسار التنقل" class="breadcrumbs">
  <ol itemscope itemtype="https://schema.org/BreadcrumbList">
    {items.map((item, i) => (
      <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        {item.href ? (
          <a itemprop="item" href={item.href}>
            <span itemprop="name">{item.label}</span>
          </a>
        ) : (
          <span itemprop="name">{item.label}</span>
        )}
        <meta itemprop="position" content={String(i + 1)} />
      </li>
    ))}
  </ol>
</nav>

<style>
.breadcrumbs { margin-bottom: var(--space-4); }
.breadcrumbs ol {
  display: flex; gap: var(--space-2); list-style: none; padding: 0; margin: 0;
  font-size: 0.8125rem; color: var(--color-gray-500); flex-wrap: wrap;
}
.breadcrumbs li:not(:last-child)::after {
  content: "/"; margin-inline-start: var(--space-2); color: var(--color-gray-300);
}
.breadcrumbs a { color: var(--color-gray-500); }
.breadcrumbs a:hover { color: var(--color-primary); }
</style>
