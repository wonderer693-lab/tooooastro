---
import StarRating from './StarRating.astro';
import type { CollectionEntry } from 'astro:content';
import { getAffiliateUrl } from '@lib/affiliates';

type Review = CollectionEntry<'review'>;

export interface Props {
  review: Review;
}

const { review } = Astro.props;
const { data, id } = review;
---

<article class="review-card card">
  <div class="review-card-header">
    <h3 class="review-card-title">
      <a href={`/software/${id}/`}>{data.title}</a>
    </h3>
    <StarRating rating={data.rating} size="sm" />
  </div>

  <p class="review-card-desc">{data.description}</p>

  <div class="review-card-meta">
    <span class="badge badge-primary">{data.bestFor}</span>
    <span class="review-card-price">{data.priceRange}</span>
  </div>

  <div class="review-card-pros">
    <strong>المميزات:</strong>
    <ul>
      {data.pros.slice(0, 3).map(p => <li>{p}</li>)}
    </ul>
  </div>

  <div class="review-card-actions">
    <a href={`/software/${id}/`} class="btn btn-outline">عرض المراجعة</a>
    <a href={getAffiliateUrl(id)} class="btn btn-primary" target="_blank" rel="noopener sponsored">زيارة الموقع</a>
  </div>
</article>

<style>
.review-card { display: flex; flex-direction: column; gap: var(--space-4); }
.review-card-header { display: flex; justify-content: space-between; align-items: flex-start; gap: var(--space-3); }
.review-card-title { margin: 0; font-size: 1.125rem; }
.review-card-title a { color: var(--color-gray-900); }
.review-card-title a:hover { color: var(--color-primary); }
.review-card-desc { color: var(--color-gray-600); font-size: 0.9375rem; margin: 0; }
.review-card-meta { display: flex; gap: var(--space-3); align-items: center; flex-wrap: wrap; }
.review-card-price { font-size: 0.875rem; color: var(--color-gray-500); font-weight: 500; }
.review-card-pros strong { font-size: 0.875rem; color: var(--color-green); }
.review-card-pros ul { margin: var(--space-1) 0 0; padding-inline-start: var(--space-4); font-size: 0.875rem; color: var(--color-gray-600); }
.review-card-pros li { margin-bottom: 2px; }
.review-card-actions { display: flex; gap: var(--space-3); margin-top: auto; padding-top: var(--space-4); border-top: 1px solid var(--color-gray-100); }
.review-card-actions .btn { flex: 1; justify-content: center; font-size: 0.875rem; }
</style>
