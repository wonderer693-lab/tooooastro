---
import type { PricingTier } from '@data/pricing';

export interface Props {
  name: string;
  tiers: PricingTier[];
  affiliateUrl?: string;
}

const { name, tiers, affiliateUrl } = Astro.props;
---

<div class="pricing-grid">
  {tiers.map(t => (
    <div class={`pricing-card ${t.highlighted ? 'pricing-highlighted' : ''}`}>
      {t.highlighted && <span class="pricing-badge">الأكثر طلبًا</span>}
      <h3 class="pricing-plan">{t.name}</h3>
      <div class="pricing-price">
        <strong>{t.price}</strong>
        <span class="pricing-period">{t.period}</span>
      </div>
      <ul class="pricing-features">
        {t.features.map(f => <li>{f}</li>)}
      </ul>
      <a href={affiliateUrl || '#'} class={`btn ${t.highlighted ? 'btn-primary' : 'btn-outline'}`} target="_blank" rel="noopener sponsored" onclick={`window.clinicSa?.trackClick('${name}')`}>
        {t.cta}
      </a>
    </div>
  ))}
</div>

<style>
.pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: var(--space-6); }
.pricing-card { display: flex; flex-direction: column; gap: var(--space-4); padding: var(--space-6); border: 1px solid var(--color-gray-200); border-radius: var(--radius); background: var(--color-white); position: relative; }
.pricing-highlighted { border-color: var(--color-primary); box-shadow: 0 4px 12px rgba(13, 148, 136, 0.15); transform: scale(1.03); }
.pricing-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--color-primary); color: var(--color-white); padding: var(--space-1) var(--space-4); border-radius: 999px; font-size: 0.75rem; font-weight: 700; white-space: nowrap; }
.pricing-plan { margin: 0; font-size: 1.125rem; }
.pricing-price { display: flex; align-items: baseline; gap: var(--space-1); }
.pricing-price strong { font-size: 2rem; color: var(--color-primary); }
.pricing-period { font-size: 0.875rem; color: var(--color-gray-500); }
.pricing-features { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-2); }
.pricing-features li { font-size: 0.875rem; color: var(--color-gray-600); padding-inline-start: var(--space-4); position: relative; }
.pricing-features li::before { content: "✓"; position: absolute; right: 0; color: var(--color-green); font-weight: bold; }
.pricing-card .btn { justify-content: center; margin-top: auto; }
@media (max-width: 768px) {
  .pricing-highlighted { transform: none; }
}
</style>
